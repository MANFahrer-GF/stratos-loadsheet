{
  "name": "stratos-loadsheet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OFP loadsheet check (Block/ZFW/TOW vs SimBrief plan) for the SkyVex Stratos ACARS client.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "icons": "node scripts/generate-icons.mjs",
    "build:ui": "vite build",
    "build:bg": "cross-env BUILD_TARGET=background vite build",
    "build": "npm run icons && npm run build:ui && npm run build:bg"
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@skyvexsoftware/stratos-sdk": "^0.10.1",
    "@types/express": "^4.17.21",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^7.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "vitest": "^2.1.0"
  }
}
